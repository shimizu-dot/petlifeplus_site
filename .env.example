# PetLifePlus — Docker Compose 環境変数サンプル
# このファイルを .env にコピーして使用してください:
#   cp .env.example .env
# .env は .gitignore に含まれているため Git にコミットされません。

# ─── DB 接続 ──────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=hs0512

# ─── アプリ設定 ───────────────────────────────────────────────────────────────
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# スキーマ・データ自動適用（always=起動時に実行 / never=スキップ）
SQL_INIT_MODE=always

# ─── AI 機能 ──────────────────────────────────────────────────────────────────
# AI 症状チェック (F-009) — 未設定時はヒューリスティックフォールバック
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# チャットボット相談 (F-022) — 未設定時はキーワードフォールバック
# Groq 無料枠: https://console.groq.com/
CHATBOT_API_KEY=
CHATBOT_MODEL=llama-3.1-8b-instant

# ─── メール (SendGrid) ────────────────────────────────────────────────────────
# 未設定時はパスワードリセットメール・請求通知メールをスキップ
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@petlife.local

# ─── Slack Bot ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
ADMIN_SLACK_USER_IDS=

# ─── LINE Messaging API ───────────────────────────────────────────────────────
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=
ADMIN_LINE_USER_IDS=

# ─── 請求通知 — 振込先・PayPay 情報 ─────────────────────────────────────────
BILLING_BANK_NAME=〇〇銀行
BILLING_BANK_BRANCH=△△支店
BILLING_BANK_ACCOUNT_NUMBER=12345678
BILLING_BANK_ACCOUNT_HOLDER=PetLife 事務局
# PayPay QR コード画像 URL（メール HTML に埋め込まれる。未設定時は PayPay ID をテキスト表示）
BILLING_PAYPAY_QR_URL=
# PayPay 送金先 ID（QR URL 未設定時のテキスト案内に使用）
BILLING_PAYPAY_ID=

# ─── Zoom オンライン診療 ──────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
