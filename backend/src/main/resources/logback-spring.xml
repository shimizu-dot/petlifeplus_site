<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

  <property name="LOG_DIR" value="logs"/>
  <property name="APP_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>
  <property name="AUDIT_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS}|%msg%n"/>
  <property name="OPS_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS}|%msg%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${APP_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/app.log</file>
    <encoder>
      <pattern>${APP_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>50MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/audit.log</file>
    <encoder>
      <pattern>${AUDIT_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>90</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <appender name="OPS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/ops.log</file>
    <encoder>
      <pattern>${OPS_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/ops.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>20MB</maxFileSize>
      <maxHistory>90</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- 本番環境（spring.profiles.active=prod）: ファイルのみ、コンソール出力なし -->
  <springProfile name="prod">
    <logger name="AUDIT" level="INFO" additivity="false">
      <appender-ref ref="AUDIT_FILE"/>
    </logger>
    <logger name="OPS" level="INFO" additivity="false">
      <appender-ref ref="OPS_FILE"/>
    </logger>
    <root level="INFO">
      <appender-ref ref="APP_FILE"/>
    </root>
  </springProfile>

  <!-- 開発環境（デフォルト / dev）: コンソール + ファイル -->
  <springProfile name="!prod">
    <logger name="AUDIT" level="INFO" additivity="false">
      <appender-ref ref="AUDIT_FILE"/>
      <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="OPS" level="INFO" additivity="false">
      <appender-ref ref="OPS_FILE"/>
      <appender-ref ref="CONSOLE"/>
    </logger>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="APP_FILE"/>
    </root>
  </springProfile>

</configuration>
